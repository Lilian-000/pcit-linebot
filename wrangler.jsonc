{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pcit-linebot",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],

  // LINE_CHANNEL_ACCESS_TOKEN 與 LINE_CHANNEL_SECRET 應透過
  // `wrangler secret put` 設定，不要寫入此檔案。
  //
  // LINE_CHANNEL_ACCESS_TOKEN and LINE_CHANNEL_SECRET should be set via
  // `wrangler secret put`, not in this file.

  "vars": {},

  // ── Workers AI: 用 gpt-oss-120b 生成防詐分析報告 ──
  // 文件 / Docs: https://developers.cloudflare.com/workers-ai/models/gpt-oss-120b/
  "ai": {
    "binding": "AI"
  },

  // ── R2: 存任務狀態與分析結果 ──
  // 建立 bucket（本機 dev 會自動模擬，無需先建立；雲端部署前才需要）：
  //   npx wrangler r2 bucket create pcit-tasks
  "r2_buckets": [
    {
      "binding": "TASK_BUCKET",
      "bucket_name": "pcit-tasks"
    }
  ],

  // ── Queue: 非同步處理 AI 任務 ──
  // 建立 queue（本機 dev 會自動模擬，無需先建立；雲端部署前才需要）：
  //   npx wrangler queues create pcit-tasks
  // Cloudflare Queue 需要 Workers Paid 方案才能在 production 使用。
  "queues": {
    "producers": [
      {
        "binding": "TASK_QUEUE",
        "queue": "pcit-tasks"
      }
    ],
    "consumers": [
      {
        "queue": "pcit-tasks",
        "max_batch_size": 1,
        "max_batch_timeout": 1,
        "max_retries": 0
      }
    ]
  }

  // ── 未來擴充用 binding（暫不啟用）──
  // ── D1（SQLite — 儲存對話紀錄、使用者偏好）──
  // "d1_databases": [
  //   {
  //     "binding": "DB",
  //     "database_name": "<DB_NAME>",
  //     "database_id": "<從 `wrangler d1 create` 輸出貼上>"
  //   }
  // ]
}
